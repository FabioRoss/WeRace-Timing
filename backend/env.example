# Copy to backend/.env and adjust. All variables are prefixed WRB_.

# Secret used to derive driver / team-manager dashboard tokens.
# CHANGE THIS — anyone who knows it can compute every dashboard link.
WRB_SECRET_SALT=change-me-please

# Shared password for the Race Control and Staff dashboards.
WRB_SAFEWORD=boxbox

# Number of independent event slots (simultaneous races).
WRB_NUM_EVENTS=3

# Public base URL used in generated links / QR codes,
# e.g. https://timing.example.com — leave empty to derive from the request.
WRB_PUBLIC_BASE_URL=

# Where raw-frame recordings (.ndjson) are stored.
WRB_RECORDINGS_DIR=recordings
